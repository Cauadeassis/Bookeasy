{
  "name": "base",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prettier:check": "prettier . --check",
    "prettier:fix": "prettier . --write",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "docker:up": "docker compose -f src/infra/compose.yaml up &",
    "docker:down": "docker compose -f src/infra/compose.yaml down",
    "docker:enter": "docker exec -it postgres_dev psql -U postgres -d postgres",
    "migrate:create": "node-pg-migrate -m src/infra/migrations create",
    "migrate:up": "node-pg-migrate -m src/infra/migrations up"
  },
  "dependencies": {
    "@react-email/render": "^2.0.4",
    "bcrypt": "^6.0.0",
    "dotenv-expand": "^12.0.3",
    "next": "16.1.6",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.19.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-jest": "^30.2.0",
    "cz-git": "^1.12.0",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "typescript": "^5"
  }
}
